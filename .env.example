# ─────────────────────────────────────────────────────────────────────────────
# PC Build Agent — configuration
# Copy to `.env` and fill in. Read at startup by src/pc_agent/config.py
# ─────────────────────────────────────────────────────────────────────────────

# Which LLM backend to use: "anthropic" (direct API) or "bedrock" (Amazon Bedrock)
LLM_PROVIDER=anthropic

# ── Direct Anthropic API (LLM_PROVIDER=anthropic) ────────────────────────────
# Get a key at https://console.anthropic.com/. Leave unset to use an `ant auth login` profile.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Any model your account can access (e.g. claude-opus-4-8, claude-sonnet-4-5).
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Amazon Bedrock (LLM_PROVIDER=bedrock) ────────────────────────────────────
# Uses your standard AWS credential chain (env vars, ~/.aws, or an assumed role).
# To use a named profile, prefix commands with AWS_PROFILE=your-profile.
AWS_REGION=us-east-1
# A Bedrock model ID / inference-profile your account is entitled to.
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6

# ── Generation / agent-loop tuning (optional; defaults in config.py) ──────────
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096
# Hard ceiling on reason->act->observe iterations per turn before the agent stops.
AGENT_MAX_STEPS=14
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3

# Where the dataset CSVs live, and where per-run JSONL traces are written.
DATA_DIR=data
TRACE_DIR=traces
