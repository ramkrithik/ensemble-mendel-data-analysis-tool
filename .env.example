# ─────────────────────────────────────────────────────────────────────────────
# Data Analysis Agent — configuration
# Copy to `.env` and fill in. Everything here is read at startup by src/data_agent/config.py
# ─────────────────────────────────────────────────────────────────────────────

# Which LLM backend to use: "anthropic" (direct API) or "bedrock" (Amazon Bedrock)
LLM_PROVIDER=anthropic

# ── Direct Anthropic API (LLM_PROVIDER=anthropic) ────────────────────────────
# Get a key at https://console.anthropic.com/. Leave unset to use an `ant auth login` profile.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Any model your account can access. Swap to what you have (e.g. claude-opus-4-8, claude-sonnet-4-5).
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Amazon Bedrock (LLM_PROVIDER=bedrock) ────────────────────────────────────
# Uses your standard AWS credential chain (env vars, ~/.aws, or an assumed role).
AWS_REGION=us-east-1
# A Bedrock model ID or inference-profile ID your account is entitled to.
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# ── Generation / agent-loop tuning (optional; sensible defaults in config.py) ─
# Temperature is only sent to models that accept it; adaptive-thinking models ignore it.
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096
# Hard ceiling on reason->act->observe iterations before the agent must answer.
AGENT_MAX_STEPS=8
# Per-request timeout (seconds) and SDK-level automatic retries.
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3

# Where per-run JSONL reasoning traces are written.
TRACE_DIR=traces
